# Copy this file to .env and fill in your values
# Never commit .env to GitHub — it's in .gitignore

# Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Gmail address the agent sends FROM
# Must be a Gmail account with App Passwords enabled (see README)
GMAIL_ADDRESS=your@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Generate at: myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email address to send reports TO (can be same as above)
ALERT_EMAIL=your@gmail.com

# SerpAPI key for Google search results (free tier: 100 searches/month)
# Get yours at serpapi.com
SERPAPI_KEY=your-serpapi-key-here
